# --- Venice AI (server-side; optional — app falls back to a mock if unset) ---
VENICE_API_KEY=
VENICE_MODEL=llama-3.3-70b
# VENICE_BASE_URL=https://api.venice.ai/api/v1

# --- Chain (Base Sepolia) ---
# Optional custom RPC (defaults to https://sepolia.base.org)
NEXT_PUBLIC_RPC_URL=

# --- x402 demo seller receiving address (verified service) ---
X402_PAY_TO=0x000000000000000000000000000000000000dEaD

# Strict mode: when "true", the x402 server keeps the paywall (402) up until a
# payment is verified on-chain (real USDC transfer to the seller). Default off so
# the funds-free demo still delivers (clearly labeled simulated).
X402_REQUIRE_ONCHAIN=false
